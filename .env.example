# Shared demo settings
DEMO_ENV=local
DEMO_PASSWORD=inat-demo
DEMO_TOKEN_SECRET=
DEMO_TOKEN_TTL_SECONDS=43200
DEMO_AUTH_ATTEMPT_LIMIT=10
DEMO_AUTH_WINDOW_SECONDS=300
PIPELINE_API_URL=http://localhost:8010
MINIO_PUBLIC_URL=http://localhost:9000
DEMO_PRESIGN_IMAGE_URLS=true
DEMO_IMAGE_URL_TTL_SECONDS=3600
DEMO_S3_ACCESS_KEY_ID=minioadmin
DEMO_S3_SECRET_ACCESS_KEY=minioadmin
DEMO_S3_REGION=us-east-1
INQUIRE_VECTOR_SEARCH_PATH=../Inquire-vector-search
RAY_API_URL=http://localhost:8265
QDRANT_API_URL=http://localhost:6333
DEMO_CONTAINER_PIPELINE_API_URL=http://host.docker.internal:8010

# Local live seed data
DEMO_LIVE_COLLECTION=inat-demo-live
DEMO_S3_BUCKET=pipeline
DEMO_S3_PREFIX=hf-inat/
DEMO_RESET_COLLECTION=1
DEMO_SEMANTIC_CACHE_ENABLED=false
DEMO_HF_IMAGES_PER_DATASET=8
DEMO_HF_MAX_ROWS_PER_DATASET=300
DEMO_HF_PAGE_SIZE=25
DEMO_HF_REQUEST_RETRIES=3
DEMO_HF_REQUEST_BACKOFF_SECONDS=2
DEMO_HF_BATCH_OFFSET_STRIDE=500
DEMO_HF_DATASETS=gt-csse/inat-open-data-embeddings,gt-csse/iNat24-vit-b-16-test,gt-csse/iNat24-vit-b-16
DEMO_VERIFY_QUERY=nudibranch
DEMO_COST_PER_1K_IMAGES_USD=0
DEMO_COST_PER_COMPUTE_HOUR_USD=0

# Server
DEMO_SERVER_HOST=0.0.0.0
DEMO_SERVER_PORT=8088
DEMO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PIPELINE_HEALTH_TIMEOUT_SECONDS=3
PIPELINE_METRICS_TIMEOUT_SECONDS=5
PIPELINE_REQUEST_TIMEOUT_SECONDS=30

# Portal
VITE_DEMO_API_URL=http://localhost:8088
